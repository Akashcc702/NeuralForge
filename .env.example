# ── NeuralForge Environment Config ──────────────────────────────────────────

# OpenRouter API key (required)
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# AI model to use (OpenRouter model string)
# Options: google/gemma-2-4b-it | anthropic/claude-3-haiku | openai/gpt-4o-mini
MODEL=google/gemma-2-4b-it

# Server port (Render sets this automatically)
PORT=3001

# Your deployed site URL (shown in OpenRouter dashboard)
SITE_URL=https://your-app.onrender.com
